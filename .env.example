# Required: an OpenRouter key (preferred — routes everything through
# OpenRouter's OpenAI-compatible endpoint), or a plain OpenAI key.
# Server-side only; never exposed to the browser.
OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...        # alternative: hits api.openai.com directly
# OPENAI_BASE_URL=...          # override for any OpenAI-compatible gateway

# The two demo deployment scenarios (UI toggle picks one per run):
# MODEL_OPEN=google/gemma-4-26b-a4b-it:nitro    # open weights = federal-laptop scenario (:nitro = fastest provider)
# MODEL_HOSTED=anthropic/claude-sonnet-4.6     # hosted API = Azure scenario
# LT_JUDGE_MODEL=                              # match judge; defaults to MODEL_HOSTED
# OPENAI_REASONING_EFFORT=low   # only applies to gpt-5-family models
# PORT=8080
# MAX_UPLOAD_MB=10
# MAX_LABELS_PER_BATCH=300
# BATCH_CONCURRENCY=8
# LLM_TIMEOUT_SECONDS=30

# Catalog matching (LinkTransformer).
# LT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# LT_JUDGE_MODEL=gpt-4o-mini
# MATCH_K=1
# MATCH_THRESHOLD=0.80
